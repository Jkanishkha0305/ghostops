# Copy to .env and fill in values — never commit .env

# ── DigitalOcean Gradient AI (Primary) ──────────────────────────
DIGITAL_OCEAN_KEY=your_digitalocean_api_token
GRADIENT_MODEL_ACCESS_KEY=your_do_model_access_key

# Provider switcher: do | gemini | groq
AI_PROVIDER=do

# ── Google Cloud (Voice + Firestore) ────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GOOGLE_CLOUD_PROJECT=your_gcp_project_id
CLOUD_RUN_URL=http://localhost:8080
FIRESTORE_SESSION_ID=default-user

# ── Optional ────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_key                 # fallback STT (Whisper)
ELEVENLABS_API_KEY=your_elevenlabs_key      # voice output (TTS)
